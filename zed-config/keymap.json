// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
  {
    "context": "Workspace",
    "bindings": {
      // "shift shift": "file_finder::Toggle"
    },
  },
  {
    "context": "Editor && vim_mode == insert",
    "bindings": {
      // "j k": "vim::NormalBefore"
    },
  },
  {
    "context": "vim_mode == insert",
    "bindings": {
      "k j": "vim::SwitchToNormalMode",
    },
  },
  {
    "context": "vim_mode == insert",
    "bindings": {
      "j k": "vim::SwitchToNormalMode",
    },
  },
  {
    "context": "Editor",
    "unbind": {
      "ctrl-space": "editor::ShowCompletions",
    },
  },
  {
    "context": "vim_mode == insert",
    "bindings": {
      "ctrl-space": "editor::ShowCompletions",
    },
  },
  {
    "context": "vim_mode == insert",
    "unbind": {
      "ctrl-x ctrl-o": "editor::ShowCompletions",
    },
  },
  {
    "context": "Workspaces",
    "bindings": {
      "ctrl-b": "workspace::ToggleLeftDock",
    },
  },
  {
    "context": "Editor && vim_mode == normal",
    "bindings": {
      "ctrl-h": "project_panel::ToggleFocus",
      "ctrl-j": "terminal_panel::ToggleFocus",
      "ctrl-l": "agent::ToggleFocus",
      "space b d": "pane::CloseActiveItem",
      "space b P": "pane::CloseAllItems",
      "space f f": "file_finder::Toggle",
      "space f w": "workspace::NewSearch",
    },
  },
  {
    "context": "ProjectPanel && !editing",
    "bindings": {
      "ctrl-l": "workspace::ActivatePreviousPane",
      "a": "project_panel::NewFile",
      "d": "project_panel::Trash",
      "r": "project_panel::Rename",
    },
  },
  {
    "context": "Terminal",
    "bindings": {
      "ctrl-k": "terminal_panel::ToggleFocus",
    },
  },
  {
    "context": "AgentPanel",
    "bindings": {
      "ctrl-h": "workspace::ActivatePreviousPane",
    },
  },
  {
    "context": "AcpThread > Editor",
    "bindings": {
      "ctrl-h": "workspace::ActivatePreviousPane",
    },
  },
  {
    "context": "ContextEditor > Editor",
    "bindings": {
      "ctrl-h": "workspace::ActivatePreviousPane",
    },
  },
  {
    "context": "Editor",
    "unbind": {
      "ctrl-k": "editor::KillRingCut",
    },
  },
]
