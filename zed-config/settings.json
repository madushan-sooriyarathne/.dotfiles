// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "context_servers": {
    "mcp-server-github": {
      "enabled": true,
      "remote": false,
      "settings": {
        "github_personal_access_token": "personal-access-token-example"
      }
    }
  },
  "agent_servers": {
    "opencode": {
      "type": "registry"
    },
    "gemini": {
      "type": "registry"
    },
    "claude-acp": {
      "type": "registry"
    }
  },
  "languages": {
    "TypeScript": {
      "language_servers": ["tsgo", "vtsls", "..."]
    }
  },
  "lsp": {
    "tailwindcss-language-server": {
      "settings": {
        "classFunctions": ["cva", "cx"],
        "experimental": {
          "classRegex": ["[cls|className]\\s\\:\\=\\s\"([^\"]*)"]
        }
      }
    }
  },
  "ssh_connections": [
    {
      "host": "dev-server",
      "args": [],
      "projects": [
        {
          "paths": ["/home/madushan/Developer/rapid-adventures-new"]
        }
      ]
    }
  ],
  "telemetry": {
    "diagnostics": true,
    "metrics": true
  },
  "vim_mode": true,
  "base_keymap": "VSCode",
  "relative_line_numbers": "enabled",
  "gutter": {
    "line_numbers": true
  },
  "buffer_font_fallbacks": [
    "Fira Code",
    "Droid Sans Mono",
    "monospace",
    "Droid Sans Fallback"
  ],
  "buffer_font_family": "Hack",
  "auto_indent_on_paste": true,
  "show_edit_predictions": true,
  "soft_wrap": "editor_width",
  "icon_theme": {
    "mode": "dark",
    "light": "Zed (Default)",
    "dark": "Material Icon Theme"
  },
  "ui_font_size": 16,
  "buffer_font_size": 15,
  "theme": {
    "mode": "dark",
    "light": "One Light",
    "dark": "Fleet Dark"
  }
}
