{
  "mcpServers": {
    "filesystem": {
      "command": "bunx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "~/Developer"
      ]
    },
    "sequential-thinking": {
      "command": "bunx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ]
    },
    "Ref": {
      "httpUrl": "https://api.ref.tools/mcp?apiKey=<API_KEY>"
    },
    "semgrep": {
      "httpUrl": "https://mcp.semgrep.ai/mcp"
    },
    "playwright": {
      "command": "bunx",
      "args": [
        "-y",
        "@playwright/mcp@latest"
      ]
    },
    "figma": {
      "command": "bunx",
      "args": [
        "-y",
        "figma-developer-mcp",
        "--figma-api-key=<FIGMA_API_KEY>",
        "--stdio"
      ]
    },
    "browser-use": {
      "command": "bunx",
      "args": [
        "-y",
        "@agent-infra/mcp-server-browser@latest"
      ]
    },
    "pencil": {
      "command": "/Applications/Pencil.app/Contents/Resources/app.asar.unpacked/out/mcp-server-darwin-arm64",
      "args": [
        "--app",
        "desktop"
      ],
      "env": {}
    }
  },
  "security": {
    "auth": {
      "selectedType": "oauth-personal"
    }
  },
  "ui": {
    "hideBanner": false,
    "showMemoryUsage": false,
    "theme": "Atom One"
  },
  "general": {
    "preferredEditor": "vim",
    "vimMode": false
  }
}