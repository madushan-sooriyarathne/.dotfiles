{
  "$schema": "https://opencode.ai/config.json",
  // Theme configuration
  "tui": {
    "scroll_speed": 3,
    "scroll_acceleration": {
      "enabled": true
    },
    "diff_style": "auto"
  },
  "model": "anthropic/claude-sonnet-4-6",
  "small_model": "anthropic/claude-haiku-4-5",
  "theme": "catppuccin",
  "autoupdate": true,
  "plugin": [
    "@tarquinen/opencode-dcp@latest",
    "octto",
    "@mohak34/opencode-notifier@latest",
    "@knikolov/opencode-plugin-simple-memory",
  ],
  "instructions": [
    "~/.config/opencode/instructions/shell_strategy.md"
  ],
  "permission": {
    "*": "allow",
    "read": "allow",
    "glob": "allow",
    "list": "allow",
    "edit": "ask",
    "bash": {
      "*": "ask",
      "git *": "ask",
      "git add *": "allow",
      "git pull *": "allow",
      "git status *": "allow",
      "git diff *": "allow",
      "git log *": "allow",
      "git branch *": "allow",
      "git checkout *": "allow",
      "rm *": "ask",
      "pnpm *": "ask",
      "pnpm dev": "allow",
      "pnpm install": "allow",
      "pnpm install *": "allow",
      "pnpm check-types": "allow",
      "pnpm check-types *": "allow",
      "pnpm run check-types *": "allow",
      "pnpm format *": "allow",
      "pnpm format:write": "ask",
      "pnpm prettier": "allow",
      "pnpm prettier *": "allow",
      "pnpm build": "allow",
      "pnpm build *": "allow",
      "pnpm run build *": "allow",
      "pnpm lint": "allow",
      "pnpm lint *": "allow",
      "pnpm run lint *": "allow",
      "pnpm test": "allow",
      "pnpm test *": "allow",
      "pnpm run test *": "allow",
      "pnpm typegen": "allow",
      "pnpm typegen *": "allow",
      "pnpm run typegen *": "allow",
      "grep *": "allow",
      "find *": "allow",
      "head *": "allow",
      "sed *": "allow",
      "sort *": "allow",
      "awk *": "allow",
      "xargs *": "allow",
      "echo *": "allow",
      "tail *": "allow",
      "cat *": "allow",
      "rg *": "allow",
    },
    "webfetch": "allow",
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 10000
  },
  "watcher": {
    "ignore": [
      "node_modules/**",
      "dist/**",
      ".git/**"
    ]
  },
  "mcp": {}
}
